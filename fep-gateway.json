  },
  "components": {
    "schemas": {
      "FepOrderSubmitRequest": {
        "required": [
          "accountId",
          "clOrdId",
          "currency",
          "orderType",
          "qty",
          "referenceId",
          "securityExchange",
          "side",
          "symbol"
        ],
        "type": "object",
        "properties": {
          "clOrdId": {
            "minLength": 1,
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
            "type": "string"
          },
          "accountId": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "symbol": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          },
          "securityExchange": {
            "type": "string",
            "enum": [
              "KRX",
              "KOSDAQ"
            ]
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
            ]
          },
          "orderType": {
            "type": "string",
            "enum": [
              "LIMIT",
              "MARKET"
            ]
          },
          "qty": {
            "type": "integer",
            "format": "int64"
          },
          "price": {
            "type": "integer",
            "format": "int64"
          },
          "quoteSnapshotId": {
            "type": "string"
          },
          "quoteAsOf": {
            "type": "string",
            "format": "date-time"
          },
          "quoteSourceMode": {
            "type": "string",
            "enum": [
              "LIVE",
              "DELAYED",
              "REPLAY"
            ]
          },
          "preTradePrice": {
            "type": "integer",
            "format": "int64"
          },
          "currency": {
            "minLength": 1,
            "type": "string"
          },
          "referenceId": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          }
        }
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "userMessageKey": {
            "type": "string"
          },
          "operatorCode": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      },
      "ApiResponseFepOrderResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/FepOrderResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FepOrderResponse": {
        "type": "object",
        "properties": {
          "clOrdId": {
            "type": "string"
          },
          "fepOrderId": {
            "type": "string"
          },
          "execType": {
            "type": "string",
            "enum": [
              "FILL",
              "PARTIAL_FILL",
              "PENDING_NEW",
              "REJECTED",
              "CANCELED"
            ]
          },
          "ordStatus": {
            "type": "string",
            "enum": [
              "FILLED",
              "PARTIALLY_FILLED",
              "PENDING",
              "UNKNOWN",
              "MALFORMED",
              "REJECTED",
              "CANCELED"
            ]
          },
          "executedQty": {
            "type": "integer",
            "format": "int64"
          },
          "executedPrice": {
            "type": "integer",
            "format": "int64"
          },
          "leavesQty": {
            "type": "integer",
            "format": "int64"
          },
          "transactTime": {
            "type": "string",
            "format": "date-time"
          },
          "queryTime": {
            "type": "string",
            "format": "date-time"
          },
          "message": {
            "type": "string"
          },
          "rejectReason": {
            "type": "string"
          },
          "canceledQty": {
            "type": "integer",
            "format": "int64"
          },
          "parseError": {
            "type": "string"
          }
        }
      },
      "FepOrderReplayRequest": {
        "required": [
          "approvedBy",
          "evidenceRef",
          "manualDecision",
          "operatorId",
          "reason"
        ],
        "type": "object",
        "properties": {
          "manualDecision": {
            "type": "string",
            "enum": [
              "APPROVE",
              "REJECT"
            ]
          },
          "operatorId": {
            "minLength": 1,
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
            "type": "string"
          },
          "approvedBy": {
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
            "type": "string"
          },
          "evidenceRef": {
            "type": "string"
          },
          "reason": {
            "minLength": 30,
            "type": "string"
          },
          "executionPrice": {
            "type": "integer",
            "description": "Required for unresolved MARKET replay approval. Values outside maxVirtualFillDeviationBps fail with VALIDATION-002.",
            "format": "int64"
          }
        }
      },
      "ApiResponseFepOrderReplayResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/FepOrderReplayResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FepOrderReplayResponse": {
        "type": "object",
        "properties": {
          "clOrdId": {
            "type": "string"
          },
          "finalStatus": {
            "type": "string",
            "enum": [
              "COMPLETED",
              "FAILED",
              "CANCELED"
            ]
          },
          "executionResult": {
            "type": "string",
            "enum": [
              "PARTIAL_FILL_CANCEL"
            ]
          },
          "executionSource": {
            "type": "string",
            "enum": [
              "FILLED",
              "VIRTUAL_FILL"
            ]
          },
          "executedQty": {
            "type": "integer",
            "format": "int64"
          },
          "executedPrice": {
            "type": "integer",
            "format": "int64"
          },
          "processedBy": {
            "type": "string"
          },
          "processedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FepOrderCancelRequest": {
        "required": [
          "cancelQty",
          "origClOrdId",
          "reason",
          "side",
          "symbol"
        ],
        "type": "object",
        "properties": {
          "origClOrdId": {
            "minLength": 1,
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
            "type": "string"
          },
          "symbol": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
            ]
          },
          "cancelQty": {
            "type": "integer",
            "format": "int64"
          },
          "reason": {
            "type": "string",
            "enum": [
              "RECOVERY",
              "EXPIRED",
              "ADMIN"
            ]
          }
        }
      },
      "ApiResponseFepOrderCancelResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/FepOrderCancelResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FepOrderCancelResponse": {
        "type": "object",
        "properties": {
          "origClOrdId": {
            "type": "string"
          },
          "cancelClOrdId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "CANCELED",
              "PARTIAL_FILL_CANCEL"
            ]
          },
          "executedQty": {
            "type": "integer",
            "format": "int64"
          },
          "canceledQty": {
            "type": "integer",
            "format": "int64"
          },
          "executedPrice": {
            "type": "integer",
            "format": "int64"
          },
          "executedAt": {
            "type": "string",
            "format": "date-time"
          },
          "canceledAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FepInternalOrderStatusRequest": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "type": "string"
          },
          "message": {
            "type": "string",
            "description": "Optional unresolved-status detail shown for UNKNOWN/PENDING/MALFORMED responses."
          },
          "rejectReason": {
            "type": "string",
            "description": "Optional exchange rejection reason surfaced on REJECTED responses."
          },
          "parseError": {
            "type": "string",
            "description": "Optional FIX parser diagnostic surfaced on MALFORMED responses."
          },
          "executedQty": {
            "type": "integer",
            "description": "Optional executed quantity for status correction paths such as PARTIALLY_FILLED.",
            "format": "int64"
          },
          "executedPrice": {
            "type": "integer",
            "description": "Optional executed price for MARKET FILLED or partial execution correction paths.",
            "format": "int64"
          },
          "recoveryStatus": {
            "type": "string",
            "description": "Optional recovery state override. Use ESCALATED before manual replay."
          },
          "requeryStatus": {
            "type": "string",
            "description": "Optional simulated requery outcome for replay paths.",
            "enum": [
              "FILLED",
              "PARTIALLY_FILLED",
              "CANCELED",
              "UNKNOWN",
              "PENDING",
              "MALFORMED",
              "REJECTED"
            ]
          },
          "requeryExecutedQty": {
            "type": "integer",
            "description": "Optional executed quantity to pair with a simulated requery outcome.",
            "format": "int64"
          },
          "requeryExecutedPrice": {
            "type": "integer",
            "description": "Optional executed price to pair with a simulated requery outcome.",
            "format": "int64"
          },
          "cancelFailureMode": {
            "type": "string",
            "description": "Optional cancel transport simulation mode.",
            "enum": [
              "NONE",
              "TIMEOUT",
              "REJECT"
            ]
          },
          "referencePrice": {
            "type": "integer",
            "description": "Optional reference price override for legacy MARKET recovery rows.",
            "format": "int64"
          }
        }
      }
    }
  }
}