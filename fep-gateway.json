{
  "openapi": "3.0.1",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:18082",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/fep/v1/orders": {
      "post": {
        "tags": [
          "fep-gateway-order-controller"
        ],
        "summary": "Submit an order",
        "operationId": "submit",
        "parameters": [
          {
            "name": "X-Internal-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-ClOrdID",
            "in": "header",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FepOrderSubmitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Submit accepted",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseFepOrderResponse"
                }
              }
            }
          },
          "401": {
            "description": "AUTH_001 referenceId ownership violation",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "VALIDATION-001 request contract or idempotency policy violation",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fep/v1/orders/{clOrdId}/replay": {
      "post": {
        "tags": [
          "fep-gateway-order-controller"
        ],
        "summary": "Replay an escalated order",
        "operationId": "replay",
        "parameters": [
          {
            "name": "X-Internal-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clOrdId",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FepOrderReplayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Replay processed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseFepOrderReplayResponse"
                }
              }
            }
          },
          "409": {
            "description": "9009 INVALID_SESSION_STATUS - replay target must be ESCALATED",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fep/v1/orders/{clOrdId}/cancel": {
      "post": {
        "tags": [
          "fep-gateway-order-controller"
        ],
        "summary": "Cancel an order",
        "operationId": "cancel",
        "parameters": [
          {
            "name": "X-Internal-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clOrdId",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FepOrderCancelRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Cancel accepted",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseFepOrderCancelResponse"
                }
              }
            }
          },
          "409": {
            "description": "9006 CANCEL_REJECTED",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "9004 TIMEOUT",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fep-internal/v1/orders/{clOrdId}/status": {
      "post": {
        "tags": [
          "fep-gateway-internal-controller"
        ],
        "operationId": "updateStatus",
        "parameters": [
          {
            "name": "X-Internal-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-ClOrdID",
            "in": "header",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          },
          {
            "name": "clOrdId",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FepInternalOrderStatusRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseFepOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fep/v1/orders/{clOrdId}/status": {
      "get": {
        "tags": [
          "fep-gateway-order-controller"
        ],
        "operationId": "status",
        "parameters": [
          {
            "name": "X-Internal-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clOrdId",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseFepOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fep-internal/v1/ping": {
      "get": {
        "tags": [
          "fep-gateway-controller"
        ],
        "operationId": "internalPing",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ping": {
      "get": {
        "tags": [
          "fep-gateway-controller"
        ],
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/errors/boom": {
      "get": {
        "tags": [
          "fep-gateway-controller"
        ],
        "operationId": "boom",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
