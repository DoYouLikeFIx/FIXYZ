# Shared MySQL credentials
MYSQL_USER=fix
MYSQL_PASSWORD=fix
MYSQL_ROOT_PASSWORD=root
MYSQL_REPLICATION_USER=replicator
MYSQL_REPLICATION_PASSWORD=replica-pass

# Deployment profile selection
DEPLOY_ENV=local
COMPOSE_PROFILES=

# Local observability stack (opt-in with COMPOSE_PROFILES=observability)
OBSERVABILITY_GRAFANA_BASE_URL=http://127.0.0.1:3000
OBSERVABILITY_PROMETHEUS_BASE_URL=http://127.0.0.1:9090
OBSERVABILITY_GRAFANA_ADMIN_USER=admin
OBSERVABILITY_GRAFANA_ADMIN_PASSWORD=admin
OBSERVABILITY_GRAFANA_MODE=link
CHANNEL_MANAGEMENT_PORT=18080
CHANNEL_MANAGEMENT_ADDRESS=127.0.0.1
COREBANK_MANAGEMENT_PORT=19081
COREBANK_MANAGEMENT_ADDRESS=127.0.0.1
FEP_GATEWAY_MANAGEMENT_PORT=18083
FEP_GATEWAY_MANAGEMENT_ADDRESS=127.0.0.1
FEP_SIMULATOR_MANAGEMENT_PORT=18082
FEP_SIMULATOR_MANAGEMENT_ADDRESS=127.0.0.1
CHANNEL_HIKARI_MAXIMUM_POOL_SIZE=48
CHANNEL_HIKARI_MINIMUM_IDLE=8

# Vault baseline (local/dev bootstrap)
VAULT_ADDR=http://localhost:8200
VAULT_CACERT=
VAULT_DEV_ROOT_TOKEN_ID=
VAULT_AUDIT_LOG_PATH=/vault/file/audit.log
GITHUB_OIDC_DISCOVERY_URL=https://token.actions.githubusercontent.com
GITHUB_OIDC_ISSUER=https://token.actions.githubusercontent.com
GITHUB_OIDC_AUDIENCE=https://github.com/DoYouLikeFIx
GITHUB_REPOSITORY_BOUND=DoYouLikeFIx/FIXYZ
GITHUB_JOB_WORKFLOW_REF_GLOB=DoYouLikeFIx/FIXYZ/.github/workflows/docs-publish.yml@*
VAULT_RUNTIME_ROLE=runtime-core-services
VAULT_ROTATION_ROLE=ops-rotate-internal-secret

# Bootstrap and runtime secret flow (do not commit real values)
INTERNAL_SECRET_BOOTSTRAP=
INTERNAL_SECRET=
COREBANK_INTERNAL_SECRET=
AUTH_TOTP_VAULT_BASE_URL=
AUTH_TOTP_VAULT_TOKEN=
AUTH_TOTP_VAULT_TRUST_STORE_PATH=
AUTH_TOTP_VAULT_TRUST_STORE_PASSWORD=
AUTH_TOTP_VAULT_TRUST_STORE_TYPE=PKCS12

# FEP market data provider (local/dev bootstrap)
FEP_MARKETDATA_PROVIDER=NONE
FEP_MARKETDATA_SOURCE_MODE=REPLAY
FEP_MARKETDATA_KIS_ENV=paper
FEP_MARKETDATA_KIS_APP_KEY=
FEP_MARKETDATA_KIS_APP_SECRET=
FEP_MARKETDATA_KIS_WS_TR_ID=H0STCNT0
FEP_MARKETDATA_KIS_WS_CUSTTYPE=P
FEP_MARKETDATA_KIS_SYMBOLS=005930
